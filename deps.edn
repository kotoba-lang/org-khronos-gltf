{:paths ["src" "test"]
 :deps {io.github.kotoba-lang/org-khronos-glb {:git/sha "87c6cced3e75616c3b9b92e3e0f6c64f228e2887"}}
 :aliases {:test {:extra-paths ["test"]
                  ;; kotoba-lang/mesher is a TEST-ONLY fixture generator (a
                  ;; real, working sdf-to-mesh producer whose output shape
                  ;; already matches this repo's LoadedMesh contract
                  ;; verbatim) for the export->parse round-trip test
                  ;; (ADR-0048 §3) — not a runtime dep of `gltf` itself.
                  :extra-deps {io.github.cognitect-labs/test-runner
                               {:git/tag "v0.5.1" :git/sha "dfb30dd"}
                               io.github.kotoba-lang/mesher
                               {:git/sha "b0946760efc82955888ced1e9c257170fb8033dd"}}
                  :main-opts ["-m" "cognitect.test-runner"]}
           ;; clj-kondo as a Clojars lib (no Homebrew/system install needed).
           :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
                  :main-opts ["-m" "clj-kondo.main" "--lint" "src" "test"
                              "--fail-level" "error"]}}}
